{
	"name": "payload",
	"version": "1.0.0",
	"description": "A blank template to get started with Payload 3.0",
	"license": "MIT",
	"type": "module",
	"scripts": {
		"build": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" next build",
		"dev": "cross-env NODE_OPTIONS=--no-deprecation next dev --port 3000",
		"devsafe": "rm -rf .next && cross-env NODE_OPTIONS=--no-deprecation next dev --port 3000",
		"generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
		"generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
		"lint": "cross-env NODE_OPTIONS=--no-deprecation eslint .",
		"payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
		"start": "cross-env NODE_OPTIONS=--no-deprecation next start --port 3000",
		"test": "pnpm run test:int && pnpm run test:e2e",
		"test:e2e": "cross-env NODE_OPTIONS=\"--no-deprecation --import=tsx/esm\" playwright test --config=playwright.config.ts",
		"test:int": "cross-env NODE_OPTIONS=--no-deprecation vitest run --config ./vitest.config.mts"
	},
	"dependencies": {
		"@repo/payload-config": "workspace:*",
		"@payloadcms/next": "catalog:",
		"@payloadcms/richtext-lexical": "catalog:",
		"@payloadcms/ui": "catalog:",
		"cross-env": "catalog:",
		"dotenv": "catalog:",
		"graphql": "catalog:",
		"next": "catalog:",
		"payload": "catalog:",
		"react": "catalog:",
		"react-dom": "catalog:",
		"sharp": "catalog:",
		"@payloadcms/db-mongodb": "catalog:"
	},
	"devDependencies": {
		"@playwright/test": "1.58.2",
		"@testing-library/react": "16.3.0",
		"@types/node": "catalog:",
		"@types/react": "catalog:",
		"@types/react-dom": "catalog:",
		"@vitejs/plugin-react": "4.5.2",
		"eslint": "catalog:",
		"eslint-config-next": "16.2.6",
		"jsdom": "28.0.0",
		"prettier": "^3.4.2",
		"tsx": "4.21.0",
		"typescript": "catalog:",
		"vite-tsconfig-paths": "6.0.5",
		"vitest": "4.0.18"
	},
	"engines": {
		"node": "^18.20.2 || >=20.9.0",
		"pnpm": "^9 || ^10"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"sharp",
			"esbuild",
			"unrs-resolver"
		]
	}
}
