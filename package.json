{
	"name": "Camping Inventory",
	"private": true,
	"scripts": {
		"build": "turbo run build",
		"clean": "rimraf node_modules packages/*/node_modules apps/*/node_modules .turbo apps/*/.next apps/*/.expo apps/*/dist packages/*/dist",
		"dev": "turbo run dev",
		"dev:payload": "turbo run dev --filter=payload",
		"dev:web": "turbo run dev --filter=web",
		"dev:docs": "turbo run dev --filter=docs",
		"dev:mobile": "turbo run dev --filter=mobile",
		"lint": "biome lint",
		"format": "biome format --write",
		"format-and-lint": "biome check",
		"check-types": "turbo run check-types"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.1",
		"@types/bun": "latest",
		"rimraf": "^6.1.3",
		"turbo": "^2.9.18",
		"typescript": "5.9.2"
	},
	"engines": {
		"node": ">=18"
	},
	"packageManager": "bun@1.3.14",
	"workspaces": {
		"packages": [
			"apps/*",
			"packages/*"
		],
		"catalog": {
			"@payloadcms/next": "3.85.1",
			"@payloadcms/richtext-lexical": "3.85.1",
			"@payloadcms/ui": "3.85.1",
			"cross-env": "^7.0.3",
			"dotenv": "16.4.7",
			"graphql": "^16.8.1",
			"next": "16.2.6",
			"payload": "3.85.1",
			"react": "19.2.6",
			"react-dom": "19.2.6",
			"sharp": "0.34.2",
			"@payloadcms/db-mongodb": "3.85.1",
			"@tanstack/react-query": "^5.62.11",
			"@types/node": "^22.15.3",
			"@types/react": "19.2.2",
			"@types/react-dom": "19.2.2",
			"eslint": "^9.39.1",
			"typescript": "5.9.2"
		}
	},
	"module": "index.ts",
	"type": "module",
	"dependencies": {
		"sharp": "^0.35.2"
	}
}
